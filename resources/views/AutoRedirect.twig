<script>
    (function() {
        console.log('[VR Payment] Auto-redirect script loaded');
        var redirectUrl = {{ redirectUrl|json_encode|raw }};
        console.log('[VR Payment] Redirect URL:', redirectUrl);
        if (redirectUrl) {
            console.log('[VR Payment] Redirecting now...');
            // Store in sessionStorage as backup
            sessionStorage.setItem('vrpayment_redirect', JSON.stringify({url: redirectUrl}));
            // Redirect immediately
            window.location.href = redirectUrl;
        }
    })();
</script>
